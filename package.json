{
  "name": "boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "npm run test --watch"
  },
  "lint-staged": {
    "src/**/*": [
      "npm run lint --fix"
    ]
  },
  "dependencies": {
    "next": "10.0.7",
    "react": "17.0.1",
    "react-dom": "17.0.1"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.10.1",
    "@testing-library/jest-dom": "^5.11.0",
    "@testing-library/react": "^10.4.3",
    "@types/jest": "^26.0.3",
    "@types/node": "14.0.14",
    "@types/react": "16.9.41",
    "@typescript-eslint/eslint-plugin": "3.4.0",
    "@typescript-eslint/parser": "3.4.0",
    "eslint": "7.3.1",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-react": "7.20.0",
    "eslint-plugin-react-hooks": "^4.0.4",
    "husky": "^8.0.0",
    "jest": "^27.4.7",
    "lint-staged": "^10.5.4",
    "prettier": "^2.0.5",
    "typescript": "3.9.5"
  }
}
